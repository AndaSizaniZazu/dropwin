# Store Analyzer API Configuration

# Lovable AI Gateway API Key (required for AI analysis)
LOVABLE_API_KEY=your_api_key_here

# Frontend API Configuration
# Local Development
VITE_API_URL=http://localhost:8000

# Production (Update with your backend URL)
# VITE_API_URL=https://your-backend-url.com
# Flask Configuration
FLASK_ENV=development
PORT=5000

# Optional: API Rate limiting and timeouts
REQUEST_TIMEOUT=30
MAX_REQUESTS_PER_MINUTE=60
